    "pinia": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
